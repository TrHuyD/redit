// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  relationMode = "foreignKeys"

}
model Account {
  id                BigInt  @id
  userId            BigInt  @unique
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       BigInt
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            BigInt    @id 
  name          String
  username      String?
  email         String?   @unique
  emailVerified DateTime?
  googleId String? @unique
  image    String
  accounts Account[]
  sessions Session[]

  posts Post[]  
  postVotes PostVote[]
  comments Comment[]
  CommentVotes CommentVote[]

  subscriptions Subscription[]

  createdSubreddits Subreddit[] @relation("CreatedBy")
}

model Subscription {
  userId BigInt
  subredditId BigInt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  subreddit Subreddit @relation(fields: [subredditId], references: [id], onDelete: Cascade)

  @@id([userId, subredditId])
  @@index([userId])
}

model Subreddit{
  id BigInt @id 
  name String @unique
  createdAt DateTime @default(now())
  latestUpdateAt DateTime @default(now())
  posts Post[]
  image    String @default("https://cdn.discordapp.com/embed/avatars/4.png")
  bannerImage String @default("")
  subscribers Subscription[]

  creatorId   BigInt
  Creator     User         @relation("CreatedBy", fields: [creatorId], references: [id])
}
model Post{
  id  BigInt @id
  title String
  content Json?
  createdAt DateTime @default(now())
  latestUpdateAt DateTime @default(now())

  subredditId BigInt
  subreddit Subreddit @relation(fields: [subredditId], references: [id], onDelete: Cascade)

  authorId BigInt
  author User @relation(fields: [authorId], references: [id])
  comments Comment[]
  votes PostVote[]

  @@index([title])
}
model Comment {
  id BigInt @id 
  content Json
  createdAt DateTime @default(now())
  latestUpdateAt DateTime @default(now())

  postId BigInt
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  authorId BigInt
  author User @relation(fields: [authorId], references: [id])

  replyToId BigInt?
  replyTo Comment? @relation("ReplyTo", fields: [replyToId], references: [id], onDelete: SetNull,onUpdate: SetNull)
  replies Comment[] @relation("ReplyTo")

  votes CommentVote[]

}


model PostVote {
  type Int

  postId BigInt
  post Post @relation(fields: [postId], references: [id])

  userId BigInt
  user User @relation(fields: [userId], references: [id])

  @@id([postId, userId])
}
model CommentVote {
  type Int

  commentId BigInt
  comment Comment @relation(fields: [commentId], references: [id])

  userId BigInt
  user User @relation(fields: [userId], references: [id])

  @@id([commentId, userId])
}